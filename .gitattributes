* text=auto eol=lf
*.mjs text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.md text

# Community Provider bytes are immutable, fingerprint-checked upstream inputs.
# Preserve their exact source formatting; provider-integrity is the change gate.
registry/community/** -text -whitespace

# License and declaration evidence is pinned by its exact upstream byte digest.
# Git must not rewrite it during a Windows autocrlf checkout.
registry/licenses/** -text
