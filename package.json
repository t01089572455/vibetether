{
  "name": "vibetether",
  "version": "1.0.0-rc.4",
  "description": "Release candidate for a beginner-friendly long-task control kernel and cold Skill broker.",
  "type": "module",
  "bin": {
    "vibetether": "./bin/vibetether.mjs"
  },
  "files": [
    "bin",
    "src",
    "registry",
    "skills",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "test:coverage": "node --test --test-concurrency=1 --experimental-test-coverage test/all.test.mjs",
    "eval": "node evals/run-routing-evals.mjs && node evals/run-longitudinal-evals.mjs --json",
    "audit:budgets": "node scripts/audit-budgets.mjs",
    "audit:release": "node scripts/audit-release.mjs",
    "audit:stage0": "node scripts/audit-stage0-baseline.mjs",
    "render:capability-status": "node scripts/render-capability-status.mjs",
    "check:syntax": "node scripts/check-syntax.mjs",
    "check": "npm run check:syntax && npm test && npm run eval && npm run audit:budgets && npm run audit:release",
    "test:compat:v063-live": "node scripts/test-live-v063-migration.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "agent-skills",
    "codex",
    "claude-code",
    "worktree",
    "context-engineering",
    "long-running-agents",
    "skill-router"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t01089572455/vibetether.git"
  },
  "bugs": {
