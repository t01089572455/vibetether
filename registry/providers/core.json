{
  "schema_version": 1,
  "policy": {
    "remote_candidates_are_installed": false,
    "curated_bundles_install_only_during_explicit_init": true,
    "curated_bundle_registry": "../bundles.json",
    "runtime_routing_installs_providers": false,
    "activation_requires_compatible_version_license_integrity_and_evaluation": true,
    "popularity_is_discovery_signal_only": true
  },
  "providers": [
    {
      "id": "vibetether-built-in-alignment",
      "kind": "built-in",
      "workflow_role": "primary",
      "phases": ["discover", "align"],
      "capabilities": ["requirements-clarification", "project-bootstrap"],
      "enabled_by_default": true
    },
    {
      "id": "vibetether-built-in-recall",
      "kind": "built-in",
      "workflow_role": "primary",
      "phases": ["align", "plan", "execute", "verify", "ship"],
      "capabilities": ["proven-path-recall"]
    },
    {
      "id": "vibetether-built-in-design",
      "kind": "built-in",
      "workflow_role": "primary",
      "phases": ["design"],
      "capabilities": ["product-design", "frontend-product-design"],
      "page_types": ["all"],
      "enabled_by_default": true
    },
    {
      "id": "vibetether-built-in-planning",
      "kind": "built-in",
      "workflow_role": "primary",
      "phases": ["plan"],
      "capabilities": ["planning"],
      "enabled_by_default": true
    },
    {
      "id": "vibetether-built-in-execution",
      "kind": "built-in",
      "workflow_role": "primary",
      "phases": ["execute"],
      "capabilities": ["implementation", "tdd", "debugging", "frontend-engineering"],
      "enabled_by_default": true
    },
    {
      "id": "vibetether-built-in-verification",
      "kind": "built-in",
      "workflow_role": "primary",
      "phases": ["verify"],
      "capabilities": ["browser-verification", "release-verification", "success-capture"],
      "enabled_by_default": true
    },
    {
      "id": "vibetether-built-in-review",
      "kind": "built-in",
      "workflow_role": "primary",
      "phases": ["review"],
      "capabilities": ["code-review", "security-review", "success-capture"],
      "enabled_by_default": true
    },
    {
      "id": "vibetether-built-in-release",
      "kind": "built-in",
      "workflow_role": "primary",
      "phases": ["ship"],
      "capabilities": ["release-verification", "success-capture"],
      "enabled_by_default": true
    },
